{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/auth/:path*", "destination": "/api" },
    { "source": "/integrations/:path*", "destination": "/api" },
    { "source": "/healthz", "destination": "/api" },
    { "source": "/:path((?!assets/|api($|/)).*)", "destination": "/index.html" }
  ]
}
