{
  "manifest_version": 3,
  "name": "Otto Tabs",
  "version": "0.1.0",
  "description": "Lets the Otto web app open tabs for you, so 'open page' steps can run unattended during auto-do.",
  "permissions": ["tabs", "tabGroups"],
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "action": { "default_popup": "popup.html", "default_title": "Otto Tabs", "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png" } },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://localhost:5273/*", "http://127.0.0.1:5273/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
