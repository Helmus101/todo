{
  "manifest_version": 3,
  "name": "Weave Tabs",
  "version": "0.1.0",
  "description": "Lets the Weave web app open tabs for you, so 'open page' steps can run unattended during auto-do.",
  "permissions": ["tabs", "tabGroups"],
  "action": { "default_popup": "popup.html", "default_title": "Weave Tabs" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://localhost:5273/*", "http://127.0.0.1:5273/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
