# Reuse the SAME values you already have in Weave's root .env.
# Either ANTHROPIC_API_KEY or DEEPSEEK_API_KEY is required (or both for fallback)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Composio API key for integrations (Gmail, Calendar, Slack, GitHub, Notion, etc.)
# Get it from https://composio.dev - this is REQUIRED for the app to function
COMPOSIO_API_KEY=

# A long random string used to sign the session cookie (any value; e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me-to-a-long-random-string

# Where the app is reachable. Locally this is the Vite dev origin; in production it's your deployed HTTPS URL.
# Composio redirects back to `${PUBLIC_URL}/integrations/callback` after connecting an app, so PUBLIC_URL must
# match your real origin in production.
PUBLIC_URL=http://localhost:5273

# Port the backend listens on (dev: behind the Vite proxy; prod: serves the built app directly).
PORT=8788

# Which Claude model to use for task generation + execution.
CLAUDE_MODEL=claude-opus-4-8

# Which DeepSeek model to use for task generation + execution (fallback if Anthropic unavailable)
DEEPSEEK_MODEL=deepseek-chat

# Cloud persistence (reuse Weave's Supabase project). Memory + tasks are saved per account so
# they survive restarts and follow you. Same values as Weave's root .env. Run web/supabase.sql once.
# Optional: set SUPABASE_SERVICE_KEY instead of the anon key to bypass RLS (more secure for multi-user).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY=
